# ╔════════════════════════════════════╗
# ║ PROJECT ENV (DIRENV)               ║
# ╚════════════════════════════════════╝
# Auto-load per-directory env vars (requires `direnv allow` per project)
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi
# Machine-specific config (Herd, etc.): use ~/.zshrc.local — see ~/.zshrc.local.example

