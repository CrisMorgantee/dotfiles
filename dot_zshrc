# ⚠️ Anything that may require console input (password prompts, y/n, etc.)
# must go ABOVE the Powerlevel10k instant prompt block.
#
# ✅ Keep this block very early for the fastest prompt paint.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ╔════════════════════════════════════╗
# ║ PATHS                              ║
# ╚════════════════════════════════════╝
# Homebrew (Apple Silicon). Keep early for commands availability.
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if command -v vivid >/dev/null 2>&1; then
  export LS_COLORS="$(vivid generate nord)"
fi

# User bins — appended after MISE (below) so one single PATH mechanism
# export is done once in "RUNTIME MANAGER (MISE)" section


# ╔════════════════════════════════════╗
# ║ COMPLETION SYSTEM                  ║
# ╚════════════════════════════════════╝
# Fast + cached compinit (big startup win vs running compinit "raw")
autoload -Uz compinit
_compdump="${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump-${ZSH_VERSION}"
compinit -d "$_compdump" -C

# ╔════════════════════════════════════╗
# ║ ZINIT (PLUGIN MANAGER)             ║
# ╚════════════════════════════════════╝
# Zinit installed via Homebrew
if [[ -f "$HOMEBREW_PREFIX/opt/zinit/zinit.zsh" ]]; then
  source "$HOMEBREW_PREFIX/opt/zinit/zinit.zsh"
fi

# ╔════════════════════════════════════╗
# ║ THEME (POWERLEVEL10K)              ║
# ╚════════════════════════════════════╝
# `lucid` silences "Loaded ..." messages (keeps init clean for instant prompt)
zinit ice depth=1 lucid
zinit light romkatv/powerlevel10k

# Load p10k config if present
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# ╔════════════════════════════════════╗
# ║ PLUGINS                            ║
# ╚════════════════════════════════════╝

# Better completion UI (fzf-tab)
zinit ice wait"0" lucid
zinit light Aloxaf/fzf-tab

# Autosuggestions
zinit ice wait"0" lucid atload"_zsh_autosuggest_start"
zinit light zsh-users/zsh-autosuggestions

# Syntax highlighting (deferred, keeps prompt snappy)
zinit ice wait"1" lucid
zinit light zdharma-continuum/fast-syntax-highlighting

# ╔════════════════════════════════════╗
# ║ RUNTIME MANAGER (MISE)             ║
# ╚════════════════════════════════════╝
# Activates shims + hooks for per-project tool versions (also sets PATH)
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
# Single PATH append: user bins (no duplicate mechanisms, no typeset -U override)
