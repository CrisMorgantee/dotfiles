# Powerlevel10k instant prompt (keep very early).
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Homebrew (Apple Silicon).
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if command -v vivid >/dev/null 2>&1; then
  export LS_COLORS="$(vivid generate nord)"
fi

# Completion (cached compinit).
autoload -Uz compinit
_compdump="${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump-${ZSH_VERSION}"
compinit -d "$_compdump" -C

# Zinit (installed via Homebrew).
if [[ -f "$HOMEBREW_PREFIX/opt/zinit/zinit.zsh" ]]; then
  source "$HOMEBREW_PREFIX/opt/zinit/zinit.zsh"
fi

# Theme (Powerlevel10k).
zinit ice depth=1 lucid
zinit light romkatv/powerlevel10k

[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# Plugins.
zinit ice wait"0" lucid
zinit light Aloxaf/fzf-tab

zinit ice wait"0" lucid atload"_zsh_autosuggest_start"
zinit light zsh-users/zsh-autosuggestions

zinit ice wait"1" lucid
zinit light zdharma-continuum/fast-syntax-highlighting

# Runtime manager (mise).
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
export PATH="$PATH:$HOME/.composer/vendor/bin:$HOME/.local/bin"

# Project env (direnv).
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# Navigation (zoxide).
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# Load modular zsh configs.
if [ -d "$HOME/.config/zsh" ]; then
  for file in "$HOME"/.config/zsh/*.zsh; do
    [ -r "$file" ] && source "$file"
  done
fi

# Local, machine-specific overrides (not versioned).
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
