[init]
	defaultBranch = main
[core]
	pager = delta
	editor = nvim
	autocrlf = input
	excludesfile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	hyperlinks = true
	hyperlinks-file-link-format = vscode://file/{path}:{line}
	syntax-theme = Nord
	features = decorations
[merge]
	conflictstyle = zdiff3
{{- $data := index . "data" -}}
{{- if and $data (index $data "name") (index $data "email") }}
[user]
	email = {{ index $data "email" }}
	name = {{ index $data "name" }}
{{- end }}
[fetch]
	prune = true
	pruneTags = true
[pull]
	rebase = true
[push]
	default = simple
	autoSetupRemote = true
[branch]
	autosetuprebase = always
[rebase]
	autostash = true
[rerere]
	enabled = true
[delta "decorations"]
	commit-decoration-style = bold yellow box
	file-style = bold yellow
	hunk-header-style = cyan
[alias]
	st = status -sb
	co = checkout
	br = branch -vv
	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(white)%s%C(reset) %C(dim white)- %an, %ar%C(reset)' --all
	pf = push --force-with-lease
