# Public-safe SSH config.
# Keep private hosts, usernames and identity files in ~/.ssh/config.local.

# Added by OrbStack: keep at the top when present.
Include ~/.orbstack/ssh/config

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentitiesOnly yes
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519

# Private/work-specific hosts should live outside the public repo.
IgnoreUnknown Include
Include ~/.ssh/config.local
